# TaskFlow — Environment Variables
# Copy this to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️  Never commit .env to git. Only .env.example is safe to commit.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8080
ENV=production                  # development | production

# ── JWT (required) ─────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=change-me-to-a-real-secret-generated-with-openssl-rand-hex-32

# ── Database ───────────────────────────────────────────────────────────────────
DB_USER=taskflow
DB_PASSWORD=taskflow_password
DB_NAME=taskflow
DB_HOST=postgres                # service name in docker-compose
DB_PORT=5432
DB_SSLMODE=disable

# Host port to expose Postgres on (for local psql access)
DB_PORT_EXPOSE=5432

# ── Frontend ───────────────────────────────────────────────────────────────────
# URL the React app uses to call the API.
# In docker-compose: keep as http://localhost:8080 (browser → API).
VITE_API_URL=http://localhost:8080

# Port the frontend nginx container is exposed on.
FRONTEND_PORT=3000
